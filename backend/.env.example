PORT=4000
# Comma-separated list. Add an ngrok frontend URL here when testing through a tunnel.
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# From Google Cloud Console > APIs & Services > Credentials (OAuth client, Desktop app type)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob
# Generate with: npm run get-token
GOOGLE_REFRESH_TOKEN=
# "primary" uses the authorized account's main calendar, or paste a specific calendar ID
GOOGLE_CALENDAR_ID=primary

# WhatsApp booking notifications (Meta Cloud API). Optional — leave blank to skip.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Your WhatsApp number to receive notifications, e.g. 15551234567 (no "+", no spaces)
WHATSAPP_NOTIFY_NUMBER=
WHATSAPP_TEMPLATE_NAME=new_booking_notification
WHATSAPP_TEMPLATE_LANGUAGE=en_US
# "template" (default) requires an approved template + Meta business verification.
# "text" sends plain free-form text without either, but only within 24h of the
# recipient messaging the business number first — a stopgap until verification is done.
WHATSAPP_MESSAGE_MODE=template

BUSINESS_TIMEZONE=America/New_York
BUSINESS_DAYS_AHEAD=60
# Minimum gap kept between bookings for travel time
BUSINESS_BUFFER_MINUTES=60

# Booking confirmation emails (sent via Gmail). Optional — leave blank to skip.
EMAIL_USER=
# Gmail App Password, NOT your regular Gmail password — see README for setup
EMAIL_APP_PASSWORD=
EMAIL_FROM_NAME=Shutter Speed Studios
# Business inbox CC'd on every confirmation email. Defaults to EMAIL_USER if left blank.
BUSINESS_EMAIL=

# YouTube Data API v3 key, used to check if the channel is actually live before embedding
# the player (avoids showing YouTube's own broken/unavailable player when offline).
# Enable "YouTube Data API v3" in the same Google Cloud project, then create an API key.
# Leave blank to always show the "not live" fallback.
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=
